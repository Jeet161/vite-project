generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum Department {
  CSE
  ECE
  EE
  ME
  CE
  IT
  CHE
  BT
  AE
  MME
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id         Int        @id @default(autoincrement())
  uniqueId   String?    @unique
  name       String
  email      String?    @unique
  phone      String?
  department Department
  role       Role
  password   String
  status     Status     @default(PENDING)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  teacherSessions  AttendanceSession[] @relation("TeacherSessions")
  attendanceRecord Attendance[]        @relation("StudentAttendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model AttendanceSession {
  id         Int        @id @default(autoincrement())
  code       String     @unique
  teacherId  Int
  department Department
  date       DateTime
  expiresAt  DateTime
  createdAt  DateTime   @default(now())

  teacher    User       @relation("TeacherSessions", fields: [teacherId], references: [id])
  records    Attendance[]
}

model Attendance {
  id         Int              @id @default(autoincrement())
  studentId  Int
  sessionId  Int
  date       DateTime
  status     AttendanceStatus @default(PRESENT)
  createdAt  DateTime         @default(now())

  student    User             @relation("StudentAttendance", fields: [studentId], references: [id])
  session    AttendanceSession @relation(fields: [sessionId], references: [id])

  @@unique([studentId, date])
}